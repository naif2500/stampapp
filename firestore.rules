rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
    

      // Allow Cloud Functions v2 (admin SDK) to write user docs
      allow write: if request.auth == null;

      // Allow the authenticated user to read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;


      match /history/{historyId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /businesses/{businessId} {

      allow read: if request.auth != null;
      
      // Allow Cloud Functions (admin SDK v2)
  allow write: if request.auth == null;


      allow write: if request.auth != null && request.auth.uid == businessId;

      match /tokens/{tokenId} {
        allow create: if request.auth != null;
  allow read: if request.auth != null && request.auth.uid == businessId;
      }

      match /customers/{customerId} {

        allow read: if request.auth != null && request.auth.uid == businessId;

        allow write: if request.auth == null || request.auth.uid == businessId;


        match /history/{historyId} {
          allow read: if request.auth != null && request.auth.uid == businessId;
          allow write: if request.auth != null && request.auth.uid == businessId;
        }
      }
    }
  }
}